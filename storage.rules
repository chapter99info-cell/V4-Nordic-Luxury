rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /payment_slips/{bookingId}/{allPaths=**} {
      // Allow write if authenticated and file is an image
      // The user can only write to the folder named after their booking (or any booking if we don't check ID)
      // For simplicity and matching the request:
      allow write: if request.auth != null && request.resource.contentType.matches('image/.*');
      
      // Allow read if authenticated (Owner needs to see it)
      allow read: if request.auth != null;
    }
  }
}
